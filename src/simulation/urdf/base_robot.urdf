<?xml version="1.0"?>
<robot name="base_robot">
    <link name="base_link">
        <visual>
            <geometry>
                    <cylinder radius="0.1" length="0.12"/>
            </geometry>
            <material name="gray">
                <color rgba="1.0 1.0 1.0 0.5"/>
            </material>
        </visual>
    </link>

    <link name="imu">
        <visual>
            <geometry>
                <box size="0.02 0.02 0.02"/>
            </geometry>
            <material name="black">
                <color rgba=".0 0.0 0.0 0.5"/>
            </material>
        </visual>
    </link>

    <joint name="imu_joint" type="fixed">
        <parent link="base_link"/>
        <child link="imu"/>
        <origin xyz="0 0 0.03" rpy="0 0 0"/>
    </joint>

</robot>
